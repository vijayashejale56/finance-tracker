# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Database
DB_URL=jdbc:postgresql://localhost:5432/financetracker
DB_USERNAME=postgres
DB_PASSWORD=root

# JWT — must be at least 64 characters
JWT_SECRET=your_very_long_secret_key_here_minimum_64_characters_required

# JWT Expiry (milliseconds)
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# CORS
CORS_ORIGINS=http://localhost:5173

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password